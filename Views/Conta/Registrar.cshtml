@model Projeto1_Web2_IF_Lucas.Models.ViewModels.RegistrarProfissionalViewModel
@*
    Lucas Wilman da Silva Crispim
    Tela única de Registro do profissional: login + tipo + dados + plano.
*@
@{
    ViewData["Title"] = "Registrar profissional";
}

<h1>Registro de Profissional</h1>
<p class="text-muted">Cadastre-se como <strong>Médico</strong> ou <strong>Nutricionista</strong>.</p>

<form asp-action="Registrar" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <h4 class="mt-3">Tipo de profissional</h4>
    <div class="mb-3">
        @foreach (var tipo in Model.Tipos)
        {
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="IdTipoProfissional"
                       id="tipo_@tipo.Id" value="@tipo.Id"
                       checked="@(Model.IdTipoProfissional == tipo.Id)" />
                <label class="form-check-label" for="tipo_@tipo.Id">@tipo.Nome</label>
            </div>
        }
        <span asp-validation-for="IdTipoProfissional" class="text-danger d-block"></span>
    </div>

    <h4>Dados de acesso</h4>
    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Senha" class="form-label"></label>
            <input asp-for="Senha" class="form-control" />
            <span asp-validation-for="Senha" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="ConfirmarSenha" class="form-label"></label>
            <input asp-for="ConfirmarSenha" class="form-control" />
            <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
        </div>
    </div>

    <h4>Dados do profissional</h4>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Cpf" class="form-label"></label>
            <input asp-for="Cpf" class="form-control" />
            <span asp-validation-for="Cpf" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="CrmCrn" class="form-label"></label>
            <input asp-for="CrmCrn" class="form-control" />
            <span asp-validation-for="CrmCrn" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Especialidade" class="form-label"></label>
            <input asp-for="Especialidade" class="form-control" />
            <span asp-validation-for="Especialidade" class="text-danger"></span>
        </div>
        <div class="col-md-2 mb-3">
            <label asp-for="Ddd1" class="form-label"></label>
            <input asp-for="Ddd1" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Telefone1" class="form-label"></label>
            <input asp-for="Telefone1" class="form-control" />
        </div>
    </div>

    <h4>Endereço</h4>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Logradouro" class="form-label"></label>
            <input asp-for="Logradouro" class="form-control" />
        </div>
        <div class="col-md-2 mb-3">
            <label asp-for="Numero" class="form-label"></label>
            <input asp-for="Numero" class="form-control" />
            <span asp-validation-for="Numero" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Bairro" class="form-label"></label>
            <input asp-for="Bairro" class="form-control" />
            <span asp-validation-for="Bairro" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="Cep" class="form-label"></label>
            <input asp-for="Cep" class="form-control" />
            <span asp-validation-for="Cep" class="text-danger"></span>
        </div>
        <div class="col-md-5 mb-3">
            <label asp-for="IdCidade" class="form-label"></label>
            <select asp-for="IdCidade" asp-items="Model.Cidades" class="form-select">
                <option value="">-- Selecione --</option>
            </select>
            <span asp-validation-for="IdCidade" class="text-danger"></span>
        </div>
        <div class="col-md-2 mb-3">
            <label asp-for="Estado" class="form-label"></label>
            <input asp-for="Estado" class="form-control" />
        </div>
    </div>

    <h4>Plano</h4>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="IdPlano" class="form-label"></label>
            <select asp-for="IdPlano" id="IdPlano" class="form-select">
                <option value="">-- Selecione --</option>
                @foreach (var plano in Model.Planos)
                {
                    <option value="@plano.Id" data-tipo="@plano.TipoId">
                        @plano.Nome (R$ @plano.Valor.ToString("0.00"))
                    </option>
                }
            </select>
            <span asp-validation-for="IdPlano" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Registrar</button>
    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-link">Já tenho conta</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Mostra apenas os planos do tipo de profissional selecionado (item extra).
        (function () {
            const planoSelect = document.getElementById('IdPlano');
            const radios = document.querySelectorAll('input[name="IdTipoProfissional"]');

            function filtrarPlanos() {
                const selecionado = document.querySelector('input[name="IdTipoProfissional"]:checked');
                const tipo = selecionado ? selecionado.value : '';
                let limparSelecao = false;
                Array.from(planoSelect.options).forEach(function (opt) {
                    if (!opt.value) return; // mantém o placeholder
                    const combina = opt.getAttribute('data-tipo') === tipo;
                    opt.hidden = !combina;
                    opt.disabled = !combina;
                    if (!combina && opt.selected) limparSelecao = true;
                });
                if (limparSelecao) planoSelect.value = '';
            }

            radios.forEach(r => r.addEventListener('change', filtrarPlanos));
            filtrarPlanos();
        })();
    </script>
}
