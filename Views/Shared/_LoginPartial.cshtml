@using Microsoft.AspNetCore.Identity
@using Projeto1_Web2_IF_Lucas.Data
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@*
    Lucas Wilman da Silva Crispim
    Partial de login exigida pelo Identity UI. Mostra login/registro quando
    deslogado e o usuário + logout quando autenticado.
*@
<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    @if (User.IsInRole(DbInitializer.RoleMedico) || User.IsInRole(DbInitializer.RoleNutricionista))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="MeusPacientes" asp-action="Index">Meus Pacientes</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="MeuPerfil" asp-action="Detalhes">Meu Cadastro</a>
        </li>
    }
    @if (User.IsInRole(DbInitializer.RoleGerenteMedico) || User.IsInRole(DbInitializer.RoleGerenteNutricionista) || User.IsInRole(DbInitializer.RoleGerenteGeral))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Profissionais" asp-action="Index">Profissionais</a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Gerenciar">Olá, @User.Identity?.Name!</a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
            <button type="submit" class="nav-link btn btn-link text-dark border-0">Sair</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Conta" asp-action="Registrar">Registrar</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Entrar</a>
    </li>
}
</ul>
