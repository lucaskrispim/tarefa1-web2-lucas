@model Projeto1_Web2_IF_Lucas.Models.TbPaciente
@*
    Lucas Wilman da Silva Crispim
    Cadastro de um novo paciente (vinculado ao profissional logado).
*@
@{
    ViewData["Title"] = "Novo paciente";
}

<h1>Novo paciente</h1>

<form asp-action="Criar" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <partial name="_CamposPaciente" />
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
