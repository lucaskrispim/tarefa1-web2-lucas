@model IEnumerable<Projeto1_Web2_IF_Lucas.Models.TbPaciente>
@*
    Lucas Wilman da Silva Crispim
    Lista apenas os pacientes do profissional logado (filtrado no controller via tbMedico_Paciente).
*@
@{
    ViewData["Title"] = "Meus pacientes";
}

<h1>Meus pacientes</h1>

@if (TempData["Mensagem"] != null)
{
    <div class="alert alert-success">@TempData["Mensagem"]</div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<p>
    <a asp-action="Criar" class="btn btn-primary">Novo paciente</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>CPF</th>
            <th>Nascimento</th>
            <th>Cidade</th>
            <th>Telefone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Nome</td>
                <td>@p.Cpf</td>
                <td>@p.DataNascimento.ToString("dd/MM/yyyy")</td>
                <td>@p.IdCidadeNavigation?.Nome</td>
                <td>@p.TelCelular</td>
                <td>
                    <a asp-action="Detalhes" asp-route-id="@p.IdPaciente">Detalhes</a> |
                    <a asp-action="Editar" asp-route-id="@p.IdPaciente">Editar</a> |
                    <a asp-action="Excluir" asp-route-id="@p.IdPaciente">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">Você ainda não cadastrou pacientes.</p>
}
