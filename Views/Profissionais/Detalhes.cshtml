@model Projeto1_Web2_IF_Lucas.Models.TbProfissional
@*
    Lucas Wilman da Silva Crispim
    Detalhes de um profissional para o gerente (somente leitura).
*@
@{
    ViewData["Title"] = "Detalhes do profissional";
}

<h1>Detalhes do profissional</h1>

<dl class="row">
    <dt class="col-sm-3">Nome</dt>
    <dd class="col-sm-9">@Model.Nome</dd>

    <dt class="col-sm-3">Tipo</dt>
    <dd class="col-sm-9">@Model.IdTipoProfissionalNavigation?.Nome</dd>

    <dt class="col-sm-3">CPF</dt>
    <dd class="col-sm-9">@Model.Cpf</dd>

    <dt class="col-sm-3">CRM / CRN</dt>
    <dd class="col-sm-9">@Model.CrmCrn</dd>

    <dt class="col-sm-3">Especialidade</dt>
    <dd class="col-sm-9">@Model.Especialidade</dd>

    <dt class="col-sm-3">Endereço</dt>
    <dd class="col-sm-9">@Model.Logradouro, @Model.Numero - @Model.Bairro (CEP @Model.Cep)</dd>

    <dt class="col-sm-3">Cidade / UF</dt>
    <dd class="col-sm-9">@(Model.IdCidadeNavigation?.Nome ?? Model.Cidade) / @Model.Estado</dd>

    <dt class="col-sm-3">Telefone</dt>
    <dd class="col-sm-9">(@Model.Ddd1) @Model.Telefone1</dd>

    <dt class="col-sm-3">Plano</dt>
    <dd class="col-sm-9">@Model.IdContratoNavigation?.IdPlanoNavigation?.Nome</dd>
</dl>

<a asp-action="Editar" asp-route-id="@Model.IdProfissional" class="btn btn-primary">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Voltar</a>
